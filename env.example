# 与代码默认一致；上线请务必改为强密码
ADMIN_PASSWORD=123456
SESSION_SECRET=请修改为随机长字符串
# 多模态：OpenAI 官方，或国内「兼容 OpenAI」的网关（密钥填各平台申请的 API Key）
OPENAI_API_KEY=
# 留空则走 OpenAI 官方；接入阿里云百炼通义千问 VL 示例：
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 接入火山方舟（豆包视觉）示例（OpenAI 兼容）：
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_BASE_URL=
# 官方示例 gpt-4o-mini；通义示例 qwen-vl-plus / qwen-vl-max 等（以控制台为准）
# 豆包视觉示例：doubao-vision-pro-32k-2410128（以火山方舟控制台为准）
OPENAI_MODEL=gpt-4o-mini
STRAY_AUTO_APPROVE_MIN_CONFIDENCE=0.78
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 推荐：Webhook 推送（对接企业微信/飞书/短信网关/自有系统）
NOTIFY_WEBHOOK_URL=
# 可选：用于签名校验（X-Signature=HMAC-SHA256(body, secret)）
NOTIFY_WEBHOOK_SECRET=

# 短信网关（推荐国内短信方式）：由你的网关服务对接具体短信供应商
SMS_GATEWAY_URL=
SMS_GATEWAY_SECRET=

# 微信小程序订阅消息（推荐国内推送方式）
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_TMPL_APPLICATION_RESULT=
WECHAT_TMPL_SURGERY_DONE=
WECHAT_MESSAGE_PAGE=pages/index/index
WECHAT_FIELDS_APPLICATION_RESULT=thing1,thing2,thing3,thing4,thing5
WECHAT_FIELDS_SURGERY_DONE=thing1,thing2,thing3

# （可选）高德逆地理编码：用于把定位经纬度显示为具体地址（后端请求，不暴露到前端）
AMAP_WEB_KEY=

# （可选）后台 zip 备份输出目录，默认 backups
# BACKUP_DIR=backups
