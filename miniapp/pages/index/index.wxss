.label { margin-top: 22rpx; font-size: 28rpx; font-weight: 700; }
.placeholder-sm { font-size: 24rpx; color: #737373; }
.sub label { display: block; margin-top: 10rpx; }
.info-note {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e5e5;
  background: #f4f4f5;
}
.info-note-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #171717;
}
.info-note-text {
  margin-top: 8rpx;
  margin-bottom: 0;
}

/* ── 代预约 ── */
.addon-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}
.addon-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9d9d9;
  background: #fafafa;
  font-size: 26rpx;
  color: #333333;
}
.addon-item.addon-checked {
  border-color: #171717;
  background: #171717;
  color: #ffffff;
}
.addon-check {
  width: 28rpx;
  height: 28rpx;
  font-size: 22rpx;
  line-height: 28rpx;
  text-align: center;
}
.proxy-info-card {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #fffbeb;
  border: 1rpx solid #fcd34d;
  border-radius: 18rpx;
}
.proxy-info-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #92400e;
}
/* 爱心展示内嵌入口 */
.showcase-inline-btn {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 22rpx;
  background: #f4f4f5;
  border: 1px solid #e5e5e5;
  border-radius: 16rpx;
}
.showcase-inline-icon {
  font-size: 44rpx;
  flex-shrink: 0;
  line-height: 1;
}
.showcase-inline-text {
  flex: 1;
  min-width: 0;
}
.showcase-inline-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #171717;
}
.showcase-inline-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #737373;
  line-height: 1.5;
}
.showcase-inline-arrow {
  font-size: 40rpx;
  color: #a3a3a3;
  flex-shrink: 0;
}
