.label { margin-top: 22rpx; font-size: 28rpx; font-weight: 700; }
.placeholder-sm { font-size: 24rpx; color: #737373; }
.sub label { display: block; margin-top: 10rpx; }
.info-note {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e5e5;
  background: #f4f4f5;
}
.info-note-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #171717;
}
.info-note-text {
  margin-top: 8rpx;
  margin-bottom: 0;
}

/* 爱心展示入口卡片 */
.showcase-entry {
  margin-top: 0;
  cursor: pointer;
}
.showcase-entry-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.showcase-entry-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}
.showcase-entry-text {
  flex: 1;
  min-width: 0;
}
.showcase-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #171717;
}
.showcase-entry-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #737373;
  line-height: 1.5;
}
.showcase-entry-arrow {
  font-size: 44rpx;
  color: #a3a3a3;
  flex-shrink: 0;
}
