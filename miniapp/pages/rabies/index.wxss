.card {
  background: #ffffff;
  margin: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,.04);
}
.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171717;
  margin-bottom: 8rpx;
}
.sub {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  margin-bottom: 16rpx;
}
.label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-top: 24rpx;
  margin-bottom: 8rpx;
}
.label:first-child { margin-top: 0; }
.input {
  width: 100%;
  border: 1.5rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #171717;
  background: #fafafa;
  box-sizing: border-box;
}
.input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.input-row .input { flex: 1; }
.btn {
  width: 100%;
  background: #171717;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 26rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 32rpx;
}
.btn.secondary {
  background: #f5f5f5;
  color: #333;
  font-weight: 500;
}
.btn.sm {
  width: auto;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  margin-top: 0;
  border-radius: 10rpx;
}
.picker {
  width: 100%;
  border: 1.5rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #171717;
  background: #fafafa;
  box-sizing: border-box;
}
.row2 {
  display: flex;
  gap: 16rpx;
}
.row2 .col { flex: 1; }
.pet-card {
  border: 2rpx solid #e0e0e0;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}
.pet-card.selected {
  border-color: #171717;
  background: #f0f0f0;
}
.pet-card-name { font-weight: 600; font-size: 30rpx; }
.pet-card-sub { font-size: 24rpx; color: #888; margin-top: 4rpx; }
.sig-wrap {
  border: 1.5rpx solid #e0e0e0;
  border-radius: 14rpx;
  overflow: hidden;
  background: #fafafa;
  position: relative;
}
.sig-canvas {
  display: block;
  width: 100%;
  height: 200rpx;
}
.sig-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 26rpx;
  color: #ccc;
  pointer-events: none;
}
.sig-bar {
  display: flex;
  justify-content: flex-end;
  padding: 12rpx 16rpx;
  border-top: 1rpx solid #e0e0e0;
  background: #f5f5f5;
}
.lookup-result {
  background: #f0fdf4;
  border: 1rpx solid #bbf7d0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #166534;
  margin-top: 12rpx;
}
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}
.tag-new { background: #dbeafe; color: #1e40af; }
.tag-found { background: #d1fae5; color: #065f46; }
.divider {
  height: 1rpx;
  background: #eee;
  margin: 24rpx 0;
}
