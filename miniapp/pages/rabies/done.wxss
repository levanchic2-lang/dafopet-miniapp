.wrap {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}
.icon { font-size: 100rpx; margin-bottom: 24rpx; }
.title { font-size: 40rpx; font-weight: 700; color: #171717; margin-bottom: 16rpx; }
.sub { font-size: 26rpx; color: #666; line-height: 1.7; margin-bottom: 32rpx; }
.info-box {
  background: #f0fdf4;
  border: 1rpx solid #bbf7d0;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  text-align: left;
  margin-bottom: 40rpx;
}
.info-row { font-size: 26rpx; color: #333; line-height: 2.2; }
.info-label { color: #6b7280; }
.steps { text-align: left; margin-bottom: 40rpx; }
.step {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  align-items: flex-start;
}
.step-num {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #1a56db;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.step-num.done { background: #16a34a; }
.step-text { font-size: 26rpx; color: #374151; line-height: 1.6; padding-top: 6rpx; }
.hint { font-size: 22rpx; color: #9ca3af; }
