<scroll-view scroll-y style="height:100vh;">
<view class="card">
  <view class="title">狂犬疫苗免疫登记</view>
  <view class="sub">请填写主人与动物信息，并在下方手写签名完成登记。</view>

  <!-- 门店 -->
  <view style="background:#fef9c3;border:1rpx solid #fde047;border-radius:12rpx;padding:16rpx 24rpx;margin-bottom:24rpx;font-size:26rpx;color:#854d0e;">
    📍 服务门店：<text style="font-weight:700;">横岗店</text>（本登记仅限横岗店使用）
  </view>

  <!-- 手机号查询 -->
  <view class="label">手机号 <text style="color:#d97706;">*</text></view>
  <view class="input-row">
    <input class="input" type="number" maxlength="11" value="{{form.owner_phone}}"
      placeholder="输入手机号自动查档" bindinput="onPhoneInput" bindblur="onPhoneLookup" />
    <button class="btn secondary sm" bindtap="onPhoneLookup">查询</button>
  </view>
  <view wx:if="{{lookupDone && customerFound}}" class="lookup-result">
    ✅ 找到档案：{{form.owner_name}}
    <text wx:if="{{pets.length}}" style="margin-left:8rpx;">· {{pets.length}} 只宠物</text>
  </view>
  <view wx:if="{{lookupDone && !customerFound}}" class="lookup-result" style="background:#fef9c3;border-color:#fde047;color:#854d0e;">
    ℹ️ 未找到档案，将自动建立新档
  </view>

  <!-- 主人信息 -->
  <view class="divider" wx:if="{{lookupDone}}" />
  <view class="label">主人姓名 <text style="color:#d97706;">*</text></view>
  <input class="input" value="{{form.owner_name}}" placeholder="真实姓名" bindinput="onNameInput" />

  <view class="label">联系地址</view>
  <view class="addr-scope">广东省 · 深圳市</view>
  <view class="sub" style="margin-bottom:12rpx;">请选择区、街道，再填写详细地址（可选）</view>
  <view class="row2">
    <view class="col">
      <view class="label" style="margin-top:0;">区 / 县</view>
      <picker mode="selector" range="{{districtNames}}" value="{{districtIndex}}" bindchange="onAddrDistrictPick">
        <view class="picker">{{districtNames[districtIndex]}}</view>
      </picker>
    </view>
    <view class="col">
      <view class="label" style="margin-top:0;">街道 / 乡镇</view>
      <picker mode="selector" range="{{streetNames}}" value="{{streetIndex}}" bindchange="onAddrStreetPick">
        <view class="picker">{{streetNames[streetIndex]}}</view>
      </picker>
    </view>
  </view>
  <view class="label">详细地址</view>
  <textarea class="addr-detail" value="{{addressDetailInput}}" maxlength="240"
    placeholder="道路、门牌号、楼栋单元等（可选）"
    auto-height show-confirm-bar="{{false}}" bindinput="onAddressDetailInput" />

  <!-- 宠物选择（有档案时显示） -->
  <view wx:if="{{pets.length > 0}}">
    <view class="divider" />
    <view class="label">选择已有宠物档案</view>
    <view wx:for="{{pets}}" wx:key="id"
      class="pet-card {{selectedPetId === item.id ? 'selected' : ''}}"
      bindtap="onSelectPet" data-pet="{{item}}">
      <view class="pet-card-name">{{item.name}} <text wx:if="{{item.species}}" style="font-weight:400;font-size:24rpx;color:#888;">· {{item.species}}</text></view>
      <view class="pet-card-sub">
        <text wx:if="{{item.breed}}">{{item.breed}}</text>
        <text wx:if="{{item.gender}}"> · {{item.gender === 'male' ? '公' : item.gender === 'female' ? '母' : '不详'}}</text>
        <text wx:if="{{item.color_pattern}}"> · {{item.color_pattern}}</text>
      </view>
    </view>
    <view class="pet-card {{selectedPetId === 0 ? 'selected' : ''}}" bindtap="onSelectNewPet">
      <view class="pet-card-name">＋ 新宠物（本次未登记过）</view>
    </view>
  </view>

  <!-- 动物信息 -->
  <view class="divider" />
  <view class="label" style="font-size:28rpx;font-weight:700;">动物基本情况</view>

  <view class="label">动物名称</view>
  <input class="input" value="{{form.animal_name}}" placeholder="宠物名字" bindinput="onAnimalNameInput" />

  <view class="row2">
    <view class="col">
      <view class="label">品种</view>
      <input class="input" value="{{form.animal_breed}}" placeholder="如：金毛" bindinput="onAnimalBreedInput" />
    </view>
    <view class="col">
      <view class="label">出生年月</view>
      <picker mode="date" fields="month" value="{{form.animal_dob}}" bindchange="onAnimalDobChange">
        <view class="picker">{{form.animal_dob || '选择年月'}}</view>
      </picker>
    </view>
  </view>

  <view class="row2">
    <view class="col">
      <view class="label">性别</view>
      <picker mode="selector" range="{{genderOptions}}" range-key="label"
        value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker">{{genderOptions[genderIndex].label}}</view>
      </picker>
    </view>
    <view class="col">
      <view class="label">毛色</view>
      <input class="input" value="{{form.animal_color}}" placeholder="如：黄白" bindinput="onAnimalColorInput" />
    </view>
  </view>

  <!-- 签名 -->
  <view class="divider" />
  <view class="label">动物主人签名 <text style="color:#d97706;">*</text></view>
  <view class="sub">请在下方空白区域手写签名</view>
  <view class="sig-wrap">
    <canvas type="2d" id="sig-canvas" class="sig-canvas"
      catchtouchstart="onSigStart" catchtouchmove="onSigMove" catchtouchend="onSigEnd" />
    <view class="sig-hint" wx:if="{{!hasSig}}">请在此手写签名</view>
    <view class="sig-bar">
      <button class="btn secondary sm" bindtap="onClearSig">清除重签</button>
    </view>
  </view>

  <!-- 提交 -->
  <button class="btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onSubmit">
    提交登记
  </button>

  <view wx:if="{{error}}" style="margin-top:16rpx;font-size:24rpx;color:#dc2626;text-align:center;">{{error}}</view>
</view>
</scroll-view>
