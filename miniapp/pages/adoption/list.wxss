.page { background: #f5f5f5; min-height: 100vh; padding: 24rpx; }
.header { margin-bottom: 24rpx; }
.header-title { font-size: 40rpx; font-weight: 700; color: #171717; }
.header-sub { font-size: 24rpx; color: #888; margin-top: 8rpx; }
.grid { display: flex; flex-direction: column; gap: 20rpx; }
.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06);
}
.card-img { width: 100%; height: 360rpx; object-fit: cover; display: block; }
.card-img-placeholder {
  width: 100%; height: 240rpx; background: #f3f4f6;
  display: flex; align-items: center; justify-content: center;
  font-size: 60rpx;
}
.card-body { padding: 24rpx 28rpx; }
.card-name { font-size: 34rpx; font-weight: 700; color: #171717; }
.card-meta { font-size: 24rpx; color: #888; margin-top: 8rpx; }
.card-personality {
  font-size: 26rpx; color: #444; margin-top: 14rpx;
  line-height: 1.6; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.card-footer {
  padding: 20rpx 28rpx; border-top: 1rpx solid #f0f0f0;
  display: flex; justify-content: flex-end;
}
.btn-detail {
  background: #171717; color: #fff; border: none;
  border-radius: 12rpx; padding: 16rpx 40rpx;
  font-size: 28rpx; font-weight: 600;
}
.empty { text-align: center; padding: 120rpx 40rpx; color: #aaa; font-size: 28rpx; }
.loading { text-align: center; padding: 80rpx; color: #aaa; font-size: 26rpx; }
