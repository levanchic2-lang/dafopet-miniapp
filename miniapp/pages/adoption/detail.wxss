.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 160rpx; }
.swiper { width: 100%; height: 480rpx; }
.swiper-img { width: 100%; height: 480rpx; display: block; object-fit: cover; }
.swiper-placeholder {
  width: 100%; height: 300rpx; background: #f3f4f6;
  display: flex; align-items: center; justify-content: center; font-size: 100rpx;
}
.card { background: #fff; margin: 20rpx 24rpx; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.05); }
.name { font-size: 40rpx; font-weight: 700; color: #171717; margin-bottom: 10rpx; }
.meta { font-size: 26rpx; color: #888; margin-bottom: 20rpx; }
.section-title { font-size: 26rpx; font-weight: 700; color: #555; margin-bottom: 10rpx; margin-top: 20rpx; }
.section-title:first-child { margin-top: 0; }
.section-text { font-size: 28rpx; color: #333; line-height: 1.7; }
.video { width: 100%; border-radius: 12rpx; margin-top: 12rpx; }
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,.08);
  display: flex; gap: 16rpx;
}
.contact-btn {
  border: none; border-radius: 16rpx; padding: 28rpx 0;
  font-size: 30rpx; font-weight: 700; flex: 1; text-align: center;
}
.phone-btn { background: #171717; color: #fff; }
.cs-btn { background: #07c160; color: #fff; }
