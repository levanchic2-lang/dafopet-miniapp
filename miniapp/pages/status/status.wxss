.label { margin-top: 18rpx; font-size: 26rpx; font-weight: 700; }

.status-head {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.status-title { font-size: 26rpx; font-weight: 800; color: #171717; }
.status-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d4d4d4;
  background: #f4f4f5;
  color: #171717;
  font-size: 24rpx;
  font-weight: 800;
}

.step-card {
  margin-top: 16rpx;
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e5e5;
  background: #f4f4f5;
}
.step-title { font-size: 30rpx; font-weight: 800; color: #171717; }
.step-desc { margin-top: 6rpx; font-size: 26rpx; color: #737373; line-height: 1.5; }

.timeline-panel {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
}
.timeline-item {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}
.timeline-item + .timeline-item {
  margin-top: 2rpx;
}
.timeline-rail {
  width: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 0 0 24rpx;
}
.timeline-dot {
  margin-top: 6rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  border: 2rpx solid #d4d4d4;
  background: #ffffff;
}
.timeline-dot.done {
  border-color: #262626;
  background: #262626;
}
.timeline-dot.current {
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid #262626;
  background: #ffffff;
}
.timeline-dot.halted {
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid #737373;
  background: #ffffff;
}
.timeline-line {
  margin-top: 8rpx;
  width: 2rpx;
  min-height: 42rpx;
  flex: 1 1 auto;
  background: #e5e5e5;
}
.timeline-line.done {
  background: #262626;
}
.timeline-body {
  flex: 1 1 auto;
  padding-bottom: 18rpx;
}
.timeline-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.timeline-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #a3a3a3;
  line-height: 1.4;
}
.timeline-label.done,
.timeline-label.current,
.timeline-label.halted {
  color: #171717;
}
.timeline-chip {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d4d4d4;
  background: #f5f5f5;
  color: #737373;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
}
.timeline-chip.current {
  border-color: #262626;
  background: #171717;
  color: #ffffff;
}
.timeline-chip.halted {
  border-color: #737373;
  background: #f5f5f5;
  color: #525252;
}
.timeline-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #737373;
  line-height: 1.4;
}

.next-card, .reason-card {
  margin-top: 14rpx;
  padding: 14rpx 14rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
}
.next-k { font-size: 22rpx; font-weight: 800; color: #737373; }
.next-v { margin-top: 6rpx; font-size: 26rpx; color: #171717; line-height: 1.6; }

.info-card { margin-top: 18rpx; }

.contact-row { display: none; }

.kv {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: 160rpx 1fr;
  gap: 10rpx 14rpx;
  align-items: start;
}
.kv .k { font-size: 24rpx; color: #737373; font-weight: 800; }
.kv .v { font-size: 26rpx; color: #171717; line-height: 1.5; word-break: break-all; }

.order-item {
  margin-top: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e5e5;
  background: #ffffff;
  overflow: hidden;
}
.order-item-open {
  border-color: #262626;
}
.order-summary {
  padding: 16rpx 16rpx;
}
.order-cat {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #171717;
  line-height: 1.25;
}
.order-top { display: flex; gap: 10rpx; align-items: center; flex-wrap: wrap; }
.order-arrow {
  margin-left: auto;
  font-size: 20rpx;
  color: #a3a3a3;
  padding-left: 8rpx;
}
.order-detail {
  padding: 0 16rpx 16rpx;
  border-top: 1rpx solid #e5e5e5;
}

.claim-card{
  margin-top: 16rpx;
  padding: 16rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e5e5;
  background: #fdfdfd;
}
.claim-title{ font-size: 28rpx; font-weight: 800; color: #171717; }
.claim-sub{ margin-top: 6rpx; font-size: 24rpx; color: #737373; line-height: 1.5; }
.claim-input{
  margin-top: 12rpx;
  padding: 16rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e5e5e5;
  background: #ffffff;
  font-size: 26rpx;
}
