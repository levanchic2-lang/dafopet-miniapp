.card {
  background: #ffffff;
  margin: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171717;
}

.sub {
  margin-top: 12rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666666;
}

.tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #4f4f4f;
}

.tip.light {
  color: #8a6a00;
}

.label {
  margin-top: 20rpx;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #171717;
  font-weight: 600;
}

.row2 {
  display: flex;
  gap: 16rpx;
}

.col {
  flex: 1;
}

.input,
.picker,
.textarea {
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 18rpx;
  background: #fafafa;
  font-size: 28rpx;
  color: #171717;
}

.textarea {
  min-height: 180rpx;
}

.slot-wrap {
  margin-top: 18rpx;
}

.slot-title {
  font-size: 24rpx;
  color: #666666;
}

.slot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 14rpx;
}

.slot-item {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9d9d9;
  background: #fafafa;
  font-size: 26rpx;
  color: #333333;
}

.slot-item.active {
  border-color: #171717;
  background: #171717;
  color: #ffffff;
}

/* ── 美容时长 & 时段 ── */
.beauty-duration-card {
  margin-top: 8rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #fffbeb;
  border: 1rpx solid #fcd34d;
}

.beauty-duration-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.beauty-duration-label {
  font-size: 26rpx;
  color: #92400e;
  font-weight: 600;
}

.beauty-duration-value {
  font-size: 30rpx;
  font-weight: 800;
  color: #78350f;
}

.beauty-disclaimer {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #9e7a30;
  padding: 0 4rpx;
}

/* ── 锁定字段 ── */
.picker-locked {
  background: #f0f0f0;
  color: #999999;
  border-color: #e0e0e0;
}

/* ── 美容附加服务 ── */
.addon-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 4rpx;
}

.addon-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9d9d9;
  background: #fafafa;
  font-size: 26rpx;
  color: #333333;
}

.addon-item.addon-checked {
  border-color: #171717;
  background: #171717;
  color: #ffffff;
}

.addon-check {
  width: 28rpx;
  height: 28rpx;
  font-size: 22rpx;
  line-height: 28rpx;
  text-align: center;
}

.btn {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  background: #171717;
  color: #ffffff;
  font-size: 30rpx;
}
